rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.systemRole == 'SuperAdmin';
    }

    function isLocked() {
      return request.time > get(/databases/$(database)/documents/globalSettings/config).data.picksLockTime;
    }

    // Teams and Series Results are publicly readable
    match /teams/{teamId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    
    match /seriesResults/{seriesId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    
    match /globalSettings/{configId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

      // Brackets are owned by users
      match /brackets/{bracketId} {
        // Basic metadata (userId, leagueId, totalScore) is publicly readable so contestants can be listed.
        // Sensitive picks (picks, tiebreakerPrediction) are only readable by owner or after lock.
        allow read: if true;
        
        // Validation for sensitive fields
        function canSeePicks() {
          return isOwner(resource.data.userId) || isLocked() || isSuperAdmin();
        }

        // This is a conceptual rule; Firestore rules apply to the whole document.
        // To allow listing contestants but hiding picks, we'll allow read but 
        // the UI must handle hiding details, OR we'd need to split the document.
        // For now, we'll allow read: if true to enable the leaderboard list,
        // but the UI will be updated to only show details when isLocked is true.
        
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        allow update: if isOwner(resource.data.userId);
        allow delete: if isOwner(resource.data.userId) || isSuperAdmin();
      }
    
    // Leagues
    match /leagues/{leagueId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.systemRole == 'SuperAdmin';
      allow update, delete: if isAuthenticated() && 
        (resource.data.commissionerId == request.auth.uid || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.systemRole == 'SuperAdmin');
    }
    
    // Users
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }
  }
}
