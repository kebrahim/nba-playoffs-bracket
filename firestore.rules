rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Teams and Series Results are publicly readable
    match /teams/{teamId} {
      allow read: if true;
      allow write: if false; // Only server/admin can write
    }
    
    match /seriesResults/{seriesId} {
      allow read: if true;
      allow write: if false; // Only server/admin can write
    }
    
    match /globalSettings/{configId} {
      allow read: if true;
      allow write: if false; // Only server/admin can write
    }

    // Brackets are owned by users
    match /brackets/{bracketId} {
      allow read: if true; // Publicly viewable brackets
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId);
    }
    
    // Leagues
    match /leagues/{leagueId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
        request.resource.data.commissionerId == request.auth.uid;
      allow update, delete: if isAuthenticated() && 
        (resource.data.commissionerId == request.auth.uid || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.systemRole == 'SuperAdmin');
    }
    
    // Users
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }
  }
}
